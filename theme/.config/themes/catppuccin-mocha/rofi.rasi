/* Catppuccin Mocha — rofi palette */
/* Loaded by ~/.config/rofi/themes/layout.rasi via @import of this file. */
* {
    bg:      #1e1e2e;
    mantle:  #181825;
    surface: #313244;
    overlay: #6c7086;
    text:    #cdd6f4;
    subtext: #bac2de;
    blue:    #89b4fa;
    mauve:   #cba6f7;
    red:     #f38ba8;
    green:   #a6e3a1;
    yellow:  #f9e2af;
    peach:   #fab387;
    lavender: #b4befe;
}
