[global]
    font = "FiraCode Nerd Font Mono 11"
    markup = full
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    width = (0, 400)
    height = 300
    origin = top-right
    offset = 10x30
    transparency = 0
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    history_length = 20
    line_height = 2
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    separator_color = frame
    startup_notification = false
    icon_position = left
    min_icon_size = 24
    max_icon_size = 32
    corner_radius = 8
    frame_width = 2
    frame_color = "#313244"

[shortcuts]
    close = ctrl+space
    close_all = ctrl+shift+space
    history = ctrl+grave
    context = ctrl+shift+period

[urgency_low]
    background = "#1e1e2e"
    foreground = "#bac2de"
    frame_color = "#313244"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 10
    default_icon = dialog-information

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
    default_icon = dialog-error
