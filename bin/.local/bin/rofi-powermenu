#!/usr/bin/env bash

SHUTDOWN="箚맓  Shutdown"
REBOOT="箚쐣  Restart"
LOGOUT="箚뛽  Logout"
LOCK="箚뙻  Lock"
SUSPEND="箚뮧  Suspend"

CHOSEN=$(printf "%s\n" "$SHUTDOWN" "$REBOOT" "$LOGOUT" "$LOCK" "$SUSPEND" \
    | rofi -dmenu -i -p "  Power" \
        -theme ~/.config/rofi/themes/powermenu.rasi)

case "$CHOSEN" in
    "$SHUTDOWN") systemctl poweroff ;;
    "$REBOOT")   systemctl reboot ;;
    "$LOGOUT")   swaymsg exit ;;
    "$LOCK")     swaylock ;;
    "$SUSPEND")  systemctl suspend ;;
esac
