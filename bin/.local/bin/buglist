#!/usr/bin/env perl
use strict;
use warnings;

use Mojo::UserAgent;
my $ua = Mojo::UserAgent->new;

use constant BUGZILLA_URL => 'https://bugzilla.mozilla.org/rest';

my $dir = shift || '.';

opendir my $dir_fh, $dir || die "can't opendir $dir: $!";
my @bugs
  = map { /^(?:[.]bare[.])?(\d+)$/ && -d "$dir/$_" ? $1 : () } readdir $dir_fh;
closedir $dir_fh || die "can't closedir $dir: $!";

foreach my $bug (@bugs) {
  my $res = $ua->get(BUGZILLA_URL . "/bug/$bug?include_fields=id,summary,status");
  my $json = $res->result->json;
  my $data  = $json->{bugs}->[0];
  if (!$data->{id}) {
    print $bug . " - Not found or private\n";
    next;
  }
  print $data->{id} . ' - ' . $data->{status} . ' - ' . $data->{summary} . "\n";
}

1;
