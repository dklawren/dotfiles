#!/usr/bin/env bash

LOGOUT="箚뛽  Logout"
SUSPEND="箚뮧  Suspend"
REBOOT="箚쐣  Restart"
SHUTDOWN="箚맓  Shutdown"

CHOSEN=$(printf "%s\n" "$LOGOUT" "$SUSPEND" "$REBOOT" "$SHUTDOWN" \
    | fuzzel --config "$HOME/.config/theme-active/fuzzel.ini" --dmenu --prompt "  Power ")

case "$CHOSEN" in
    "$LOGOUT")   swaymsg exit ;;
    "$SUSPEND")  systemctl suspend ;;
    "$REBOOT")   systemctl reboot ;;
    "$SHUTDOWN") systemctl poweroff ;;
esac
